CHAT_PROVIDER=foundry

# Agent prompt configuration
AGENT_PROMPT_FILE=agents/default.yaml

# Azure OpenAI mode
AZURE_OPENAI_ENDPOINT=https://<your-openai-or-foundry-account>.services.ai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=<your-chat-deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21

# Foundry mode (project endpoint + chat deployment)
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-project-name>/
FOUNDRY_API_KEY=
FOUNDRY_CHAT_DEPLOYMENT=<your-chat-deployment-name>
FOUNDRY_API_VERSION=2024-10-21

# Optional Azure AI Search grounding (used with either provider mode)
# To enable, set BOTH endpoint and index name. Leave blank to disable.
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_INDEX_NAME=

# Optional search tuning
AZURE_AI_SEARCH_SEMANTIC_CONFIGURATION=
AZURE_AI_SEARCH_QUERY_TYPE=semantic
AZURE_AI_SEARCH_IN_SCOPE=true
AZURE_AI_SEARCH_STRICTNESS=3
AZURE_AI_SEARCH_TOP_N_DOCUMENTS=5

# Optional MCP-like OpenAPI tool interface
# Set MCP_OPENAPI_SPEC_URL to enable /mcp commands in chat_cli.py
MCP_OPENAPI_SPEC_URL=
# Optional explicit API base URL for MCP tools. Leave blank to auto-resolve from spec.
MCP_BASE_URL=
# Request timeout (seconds) for loading spec and tool calls
MCP_TIMEOUT_SECONDS=30
# Optional default headers as JSON object, example: {"x-api-key":"<key>"}
MCP_DEFAULT_HEADERS={}
